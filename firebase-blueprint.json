{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string" },
        "activeStreak": { "type": "integer" },
        "points": { "type": "integer" }
      },
      "required": ["uid", "email"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "A carbon emission log tracked by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string" },
        "co2Emoji": { "type": "string" },
        "co2Saved": { "type": "number" },
        "carbonFootprint": { "type": "number" },
        "details": { "type": "object" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "timestamp", "type", "carbonFootprint"]
    },
    "EcoChallenge": {
      "title": "Eco Challenge",
      "description": "Sustabaility challenges and completion state for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "co2Value": { "type": "number" },
        "points": { "type": "number" },
        "completed": { "type": "boolean" },
        "category": { "type": "string" }
      },
      "required": ["id", "title", "completed"]
    },
    "AICoachMessage": {
      "title": "AI Coach Message",
      "description": "Interaction messages in the sustainability coach coach chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "#/entities/ActivityLog",
      "description": "User logged activities"
    },
    "/users/{userId}/challenges/{challengeId}": {
      "schema": "#/entities/EcoChallenge",
      "description": "User specific eco challenge milestones and states"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "#/entities/AICoachMessage",
      "description": "Sustainability coach chatbot history logs"
    }
  }
}
